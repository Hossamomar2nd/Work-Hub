# Existing Mongo backend settings
PORT=3000
CONNECTION_URL="mongodb://localhost:27017/workhub"
# Required for Auth JWT signing and verification.
TOKEN_SECRETkEY="replace-with-a-long-random-secret"
# Optional; auth token expiry falls back to "1d" when omitted.
JWT_EXPIRES_IN="1d"
BEARER_KEY="Bearer"
# Optional; password hashing falls back to 10 rounds when omitted.
SALT_ROUND=10

# Future PostgreSQL + Prisma settings
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workhub?schema=public"
